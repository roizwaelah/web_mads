# ==================================================
# Root .htaccess (security + performance baseline)
# ==================================================

# Disable directory listing
Options -Indexes

# Protect sensitive files
<FilesMatch "(?i)^(?:\.env|composer\.(?:json|lock)|package(?:-lock)?\.json|mads\.sql|\.gitignore|\.htaccess)$">
    Require all denied
</FilesMatch>

# Deny direct access to API config and internal PHP helpers
<FilesMatch "(?i)^(?:config\.php|db_info\.php|settings_probe\.php|strip_bom\.php)$">
    Require all denied
</FilesMatch>

<IfModule mod_headers.c>
    # Basic hardening headers
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

    # Remove X-Powered-By if present
    Header always unset X-Powered-By
</IfModule>

# Compression
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Browser caching
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType font/woff2 "access plus 30 days"
    ExpiresDefault "access plus 1 day"
</IfModule>

# Front-controller style routing for SPA (Vite build)
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Allow existing files/directories directly
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Fallback to index.html for client-side routes
    RewriteRule . /index.html [L]
</IfModule>
